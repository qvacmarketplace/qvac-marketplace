# Solana RPC endpoint
SOLANA_RPC=https://api.devnet.solana.com

# Path to your provider keypair (64-byte array from solana-keygen).
# Generate: solana-keygen new -o ~/.config/solana/provider.json
# Fund:     solana airdrop 2 ~/.config/solana/provider.json --url devnet
SOLANA_KEYPAIR_PATH=/home/you/.config/solana/provider.json

# 32-byte hex DHT seed — generate ONCE and keep stable across restarts.
# Changing this triggers a rotate_peer_id transaction on-chain (small fee).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QVAC_HYPERSWARM_SEED=

# Display name shown in the marketplace UI (overrides qvac.config.json name).
PROVIDER_NAME=My AI Node
