# Solana RPC endpoint
SOLANA_RPC=https://api.devnet.solana.com

# Consumer keypair — only needed for demo mode (bridge auto-signs without Phantom).
# Skip this line if you will use Phantom to sign transactions in the browser.
# Generate: solana-keygen new -o ~/.config/solana/consumer.json
# Fund:     solana airdrop 2 ~/.config/solana/consumer.json --url devnet
# SOLANA_KEYPAIR_PATH=/home/you/.config/solana/consumer.json
